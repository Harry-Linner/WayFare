---
/**
 * src/components/common/NewProjectModal.astro
 * 职责：实现新建知识库的画像建立问卷（功能 2）
 * 配色：背景 #E1FCF6 (Light blue)，强调色 #A3D1CC (Blue)
 */
---

<dialog id="new-project-modal" class="backdrop:bg-black/60 p-0 rounded-3xl overflow-hidden border-none shadow-2xl">
  <div class="bg-brand-surface w-[500px] max-w-full p-8 flex flex-col gap-6">
    <div class="flex justify-between items-center">
      <h2 class="text-2xl font-black text-gray-800 tracking-tight">新建知识库项目</h2>
      <button onclick="this.closest('dialog').close()" class="text-gray-400 hover:text-gray-600 transition-colors">✕</button>
    </div>

    <form class="space-y-6" id="new-project-form">
      <div class="space-y-2">
        <label class="text-[10px] font-bold text-brand-blue uppercase tracking-widest px-1">项目标识符 (kbId)</label>
        <input 
          type="text" 
          name="kbId"
          required
          placeholder="例如：2026_CS_408" 
          class="w-full px-4 py-3 bg-white border border-brand-blue/10 rounded-2xl focus:ring-4 focus:ring-brand-blue/20 focus:border-brand-blue outline-none transition-all"
        />
      </div>

      <div class="space-y-2">
        <label class="text-[10px] font-bold text-brand-blue uppercase tracking-widest px-1">学习模式 (决定 Skill 调度)</label>
        <div class="grid grid-cols-2 gap-3">
          <label class="cursor-pointer group">
            <input type="radio" name="goal" value="structured" class="hidden peer" checked />
            <div class="p-4 bg-white border-2 border-transparent rounded-2xl peer-checked:border-brand-blue peer-checked:bg-brand-blue/5 transition-all text-center">
              <span class="block font-bold text-gray-800 group-hover:text-brand-blue">规律学习</span>
              <span class="text-[10px] text-gray-500">自动生成路线图与计划</span>
            </div>
          </label>
          <label class="cursor-pointer group">
            <input type="radio" name="goal" value="casual" class="hidden peer" />
            <div class="p-4 bg-white border-2 border-transparent rounded-2xl peer-checked:border-brand-blue peer-checked:bg-brand-blue/5 transition-all text-center">
              <span class="block font-bold text-gray-800 group-hover:text-brand-blue">随性探索</span>
              <span class="text-[10px] text-gray-500">不生成多余配置文件</span>
            </div>
          </label>
        </div>
      </div>

      <div class="space-y-2">
        <label class="text-[10px] font-bold text-brand-blue uppercase tracking-widest px-1">存储位置</label>
        <div class="p-4 bg-white/50 rounded-2xl border border-dashed border-brand-blue/30 flex items-center gap-3">
          <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-lg shadow-sm">📂</div>
          <div class="flex-1 overflow-hidden">
            <p id="path-preview" class="text-xs text-brand-blue font-mono truncate">/Users/Docs/KnowledgeBase/new-repo</p>
          </div>
          <button type="button" id="btn-change-path" class="text-[10px] bg-brand-blue text-white px-3 py-1.5 rounded-lg font-bold hover:bg-brand-blue/80 transition-colors">
            选择目录
          </button>
        </div>
      </div>

      <button type="submit" class="w-full py-4 bg-brand-blue text-white rounded-2xl font-bold text-lg shadow-lg shadow-brand-blue/30 hover:-translate-y-1 active:scale-95 transition-all">
        初始化项目
      </button>
    </form>
  </div>
</dialog>

<script>
  const form = document.getElementById('new-project-form');
  const pathPreview = document.getElementById('path-preview');
  const btnChangePath = document.getElementById('btn-change-path');

  // 模拟目录选择功能
  btnChangePath?.addEventListener('click', () => {
    // 这里将来会调用 C++/Go 暴露的文件选择原生接口
    const mockPath = "/Users/Study/2026_Exam_Library";
    if (pathPreview) pathPreview.innerText = mockPath;
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    console.log('正在初始化知识库画像:', data);
    
    // 逻辑：调用后端 API (Go Gateway) 建立物理文件夹并写入 .kb_config.json
    // 这里演示跳转
    const kbId = data.kbId || 'default';
    alert(`项目 ${kbId} 初始化成功！正在跳转至工作台...`);
    window.location.href = `/workspace/${kbId}`;
  });
</script>

<style>
  /* 弹窗背景模糊动画 */
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  /* 入场动画 */
  dialog[open] {
    animation: zoomIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes zoomIn {
    from { opacity: 0; transform: scale(0.9) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>