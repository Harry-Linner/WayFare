# ========================
# 1. Python 忽略项 (AI后端)
# ========================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env             # 绝对不能传秘钥！
wayfare_ai_backend/logs/   # 忽略本地运行日志

# ========================
# 2. Go 忽略项 (网关)
# ========================
wayfare_go_gateway/uploads/  # 忽略用户上传的测试 PDF 文件
*.exe                        # 忽略 Go 编译出来的 Windows 可执行文件

# ========================
# 3. 操作系统及编辑器忽略项
# ========================
.vscode/
.idea/
.DS_Store
node_modules
